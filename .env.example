# Environment Variables for LLM Knowledge Distillation Project
# ============================================================

# Model Configuration
# -------------------
# Teacher model name (Hugging Face Hub)
TEACHER_MODEL=Qwen/Qwen2.5-7B-Instruct

# Student model name (Hugging Face Hub)
STUDENT_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Dataset Configuration
# ---------------------
# Dataset name (Hugging Face Hub)
DATASET_NAME=databricks/databricks-dolly-15k

# Training Configuration
# ----------------------
# Number of training epochs
NUM_EPOCHS=3

# Batch size per device
BATCH_SIZE=1

# Gradient accumulation steps
GRADIENT_ACCUMULATION_STEPS=8

# Learning rate
LEARNING_RATE=2e-4

# Distillation Configuration
# --------------------------
# Temperature for softening distributions
TEMPERATURE=2.0

# Alpha: Weight for cross-entropy loss (0.0-1.0)
ALPHA=0.3

# Beta: Weight for KL divergence loss (0.0-1.0)
BETA=0.7

# LoRA Configuration
# ------------------
# LoRA rank
LORA_R=16

# LoRA alpha
LORA_ALPHA=32

# LoRA dropout
LORA_DROPOUT=0.05

# Hardware Configuration
# ----------------------
# CUDA visible devices
CUDA_VISIBLE_DEVICES=0

# Mixed precision (bf16, fp16, or fp32)
MIXED_PRECISION=bf16

# Paths
# -----
# Output directory for artifacts
OUTPUT_DIR=./artifacts

# Model path for inference
MODEL_PATH=./artifacts/best_model/final

# Base model for LoRA inference (if applicable)
BASE_MODEL=

# Optuna Configuration
# --------------------
# Number of trials for Round 1
OPTUNA_ROUND1_TRIALS=20

# Timeout for Round 1 (seconds)
OPTUNA_ROUND1_TIMEOUT=3600

# Number of trials for Round 2
OPTUNA_ROUND2_TRIALS=75

# Timeout for Round 2 (seconds)
OPTUNA_ROUND2_TIMEOUT=28800

# Weights & Biases (Optional)
# ---------------------------
# Enable W&B logging
WANDB_ENABLED=false

# W&B project name
WANDB_PROJECT=llm-distillation

# W&B API key (optional)
WANDB_API_KEY=

# Hugging Face (Optional)
# -----------------------
# Hugging Face token for private models
HF_TOKEN=

# Cache directory for models
HF_HOME=~/.cache/huggingface
